# signal_platform/.env — copy to .env and fill in values
#
# CRITICAL: DATABASE_URL must point at the SAME PostgreSQL as the Node.js app.
# This is what makes signals appear in the AssetPage — both systems read/write
# the same trading_signals table. Without this, signals are invisible to the UI.
#
# Get your DATABASE_URL from the main app's .env at the project root.

DATABASE_URL=postgresql://user:password@host:5432/dbname

# Scanner
SCAN_ENABLED=true
MIN_RR=2.0
MIN_CONFIDENCE=0.70

# News filter (source: Forex Factory JSON feed — no key required)
NEWS_PRE_WINDOW_MINS=15
NEWS_POST_WINDOW_MINS=15

# Telegram — get token from @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini AI chart validation (optional — signals pass automatically when absent)
GEMINI_API_KEY=

# OANDA (replaces yfinance — swap candle_fetcher._fetch_sync() when ready)
BROKER_API_KEY=
BROKER_API_SECRET=
