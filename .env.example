# =============================================================================
# TradeSync — Environment Variables Reference
# Copy this file to .env and fill in every value marked  ← REQUIRED
# Generate secrets with:  openssl rand -hex 32
# =============================================================================

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://tradesync:YOUR_DB_PASSWORD@localhost:5432/tradesync   # ← REQUIRED

# ── Session secret (Node.js) ──────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME   # ← REQUIRED  (openssl rand -hex 32)

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=            # ← needed for AI signal validation & trade analysis

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # ← needed for Telegram notifications & signal parsing

# ── Redis (trade queue) ───────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=            # leave blank if Redis is on localhost with no auth

# ── Copy Trading API ──────────────────────────────────────────────────────────
COPY_API_HOST=0.0.0.0
COPY_API_PORT=8001
COPY_API_SECRET=CHANGE_ME  # ← REQUIRED  (openssl rand -hex 24)

# Shared secret between bridge container and Node.js app (internal routes only)
BRIDGE_SECRET=CHANGE_ME     # ← REQUIRED  (openssl rand -hex 32)

# ── Copy Trading Encryption key ───────────────────────────────────────────────
# Used to encrypt stored MT5 account passwords in the database.
COPY_ENCRYPTION_KEY=       # ← REQUIRED for copy trading  (openssl rand -hex 32)

# ── MT5 Docker Bridge (mt5linux → gmag11/metatrader5_vnc container) ──────────
# When running via docker-compose the bridge host is the service name "mt5".
# Port 8812 is the mt5linux RPyC port exposed by the MT5 container.
MT5_BRIDGE_HOST=mt5
MT5_BRIDGE_PORT=8812
MT5_POLL_INTERVAL=3.0        # 3-second poll — balanced for single-terminal Path B
MT5_RECONNECT_ATTEMPTS=5
MT5_RECONNECT_DELAY=5.0

# VNC password for the MT5 Docker container (browser VNC at localhost:3010)
VNC_PASSWORD=CHANGE_ME       # ← REQUIRED  (set a strong password)

# ── Telegram session storage ──────────────────────────────────────────────────
TELEGRAM_SESSION_DIR=/var/lib/tradesync/tg_sessions

# ── Worker tuning ─────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
COPY_LOG_LEVEL=INFO

# ── Trade execution notifications (Telegram bot) ──────────────────────────────
# The bridge sends a message on OPEN/CLOSE success, failure, and skipped trades.
# Get a token from @BotFather.  NOTIFY_CHAT_ID is the admin chat or channel ID.
# Leave blank to disable notifications.
NOTIFY_BOT_TOKEN=
NOTIFY_CHAT_ID=

# ── Supabase Auth ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co   # ← REQUIRED
VITE_SUPABASE_ANON_KEY=sb_publishable_...            # ← REQUIRED  (Settings → API → Project API keys → publishable)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...              # ← REQUIRED  (Settings → API → Project API keys → secret)

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
PYTHON_BIN=/usr/bin/python3

# ── Optional: Economic Calendar APIs ─────────────────────────────────────────
EODHD_API_KEY=             # 20 free calls/day — https://eodhd.com
FINNHUB_API_KEY=           # fallback economic data
FMP_API_KEY=               # fallback economic data
